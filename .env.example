# Vector Graph Memory - Environment Configuration

# === Database Configuration ===
# NOTE: When running API via Docker, these are overridden in docker-compose.yml
#       to use container names (qdrant, janusgraph) instead of localhost.
#       These localhost values are for local development only.
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
JANUSGRAPH_HOST=localhost
JANUSGRAPH_PORT=8182

# === LLM Configuration ===
# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Model (supports PydanticAI format: openai:gpt-4o-mini, anthropic:claude-3-5-sonnet-20241022, etc.)
LLM_MODEL=openai:gpt-4o-mini

# === Memory Configuration ===
# Project identifier (unique namespace for memory storage)
PROJECT_ID=default

# Use case description (guides the agent's memory behavior)
MEMORY_USE_CASE=General purpose conversational memory

# Memory threshold description (what should be stored)
MEMORY_THRESHOLD=Store important facts, decisions, and context from conversations

# Similarity threshold for duplicate detection (0.0-1.0)
SIMILARITY_THRESHOLD=0.85

# === Memory Trigger Configuration ===
# Trigger mode: 'ai_determined', 'phrase', or 'interval'
TRIGGER_MODE=ai_determined

# Trigger phrase (only used if TRIGGER_MODE=phrase)
# TRIGGER_PHRASE=save this to memory

# Trigger interval in messages (only used if TRIGGER_MODE=interval)
# TRIGGER_INTERVAL=5

# === System Prompt ===
SYSTEM_PROMPT=You are a helpful AI assistant with persistent memory capabilities.

# === Audit Configuration ===
# Audit backend: 'jsonl' or 'mongodb'
AUDIT_BACKEND=jsonl

# Audit log directory (for JSONL backend)
AUDIT_LOG_DIR=~/.vgm/logs

# MongoDB connection (only if AUDIT_BACKEND=mongodb)
# AUDIT_MONGODB_URI=mongodb://localhost:27017
# AUDIT_MONGODB_DATABASE=vgm_audit
# AUDIT_MONGODB_COLLECTION=logs

# === API Configuration ===
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# === Docker Configuration ===
# Qdrant version
QDRANT_VERSION=v1.12.5

# JanusGraph version
JANUSGRAPH_VERSION=latest
