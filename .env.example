# Docker Compose Configuration
# These variables control the Docker containers

# Qdrant Vector Database
QDRANT_VERSION=latest
QDRANT_CONTAINER_NAME=vector-graph-qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# JanusGraph Graph Database
JANUSGRAPH_VERSION=latest
JANUSGRAPH_CONTAINER_NAME=vector-graph-janusgraph
JANUSGRAPH_PORT=8182

# Application Configuration
# These variables are used by the Python application to connect to databases

QDRANT_HOST=localhost
QDRANT_PORT=6333

JANUSGRAPH_HOST=localhost
